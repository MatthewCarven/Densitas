# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# --- Virtualenvs ---
.venv/
venv/
env/
ENV/

# --- Test / coverage ---
.pytest_cache/
.coverage
.coverage.*
.tox/
htmlcov/
# Per-session pytest cache directories (created when .pytest_cache is locked).
pytest-cache-files-*/

# --- Type checkers / linters ---
.mypy_cache/
.ruff_cache/
.pyright/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- OS junk ---
Thumbs.db
desktop.ini
ehthumbs.db
ehthumbs_vista.db

# --- Densitas build outputs ---
# Produced by build.cmd --exe. PyInstaller emits both build\ and dist\
# (already covered by the Python section above) plus a *.spec file.
*.spec

# --- Densitas-specific ---
# Local config overrides (if we ever add one)
config.local.toml
# Save files / playtest captures (when those exist)
saves/
playtest/
*.densitas-save

# --- Generated thumbnails / debug renders ---
# These are produced by headless smoke tests during development. Keep the
# checked-in glyph HTML; ignore one-off PNGs.
p0_world_thumb.png
p0_viewport.png
*.debug.png

# --- Cowork session scratch (added 2026-05-22) ---
# Throwaway helpers produced during Claude-assisted sessions: per-PR
# `add_X.cmd` stagers, `commit_msg_X.txt` message stashes, `commit_X.cmd`
# commit-and-push scripts, and `verify_X.cmd` post-write sanity checks.
# Useful during the work, noise afterward.
add_*.cmd
commit_*.cmd
commit_msg_*.txt
verify_*.cmd
# Atomic-rename temp files left over if a write was interrupted.
*.tmp
